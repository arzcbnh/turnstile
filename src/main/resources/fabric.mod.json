{
  "schemaVersion": 1,
  "id": "turnstile",
  "version": "${version}",
  "name": "Turnstile",
  "description": "Automatic player authentication for offline servers via subdomain tokens. No commands needed!",
  "authors": [
    {
      "name": "arzcbnh",
      "contact": {
        "email": "contact@arzcbnh.dev",
        "homepage": "https://arzcbnh.dev"
      }
    }
  ],
  "contact": {
    "issues": "https://github.com/arzcbnh/turnstile/issues",
    "sources": "https://github.com/arzcbnh/turnstile"
  },
  "license": "All-Rights-Reserved",
  "icon": "assets/turnstile/icon.png",
  "environment": "server",
  "entrypoints": {
    "main": [
      "dev.arzcbnh.minecraft.turnstile.Turnstile"
    ]
  },
  "mixins": [
    "turnstile.mixins.json"
  ],
  "accessWidener": "turnstile.classtweaker",
  "depends": {
    "fabricloader": "*",
    "fabric-api": "${fabric_version}",
    "minecraft": "${minecraft_version}"
